{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://YOUR_OTEL_COLLECTOR:4317",
    "OTEL_METRIC_EXPORT_INTERVAL": "60000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000"
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-secret-scan.sh",
            "timeout": 30,
            "statusMessage": "Scanning staged changes for secrets..."
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(which *)",
      "Bash(python* --version)",
      "Bash(node --version)",
      "Bash(npm list*)",
      "Bash(pip list*)"
    ],

    "deny": [
      "Bash(shred *)",
      "Bash(mkfs*)",
      "Bash(dd *)",

      "Bash(cat *id_rsa*)",
      "Bash(cat *id_ed25519*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat .env*)",
      "Bash(cat *credentials*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.kube/config*)",
      "Bash(cat *.token)",
      "Bash(printenv *SECRET*)",
      "Bash(printenv *API_KEY*)",
      "Bash(printenv *PRIVATE_KEY*)",
      "Bash(printenv *ACCESS_KEY*)",
      "Bash(printenv *TOKEN*)",
      "Bash(printenv *PASSWORD*)",

      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(curl -d @*)",
      "Bash(curl --data @*)",
      "Bash(nc *)",
      "Bash(netcat *)",

      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(doas *)",

      "Bash(crontab *)",
      "Bash(launchctl *)",
      "Bash(systemctl enable *)",
      "Bash(nohup *)",

      "Bash(terraform destroy*)",
      "Bash(aws * delete*)",
      "Bash(gcloud * delete*)",
      "Bash(kubectl delete *)",

      "Bash(apt-get install *)",
      "Bash(apt install *)",
      "Bash(npm install -g *)",
      "Bash(pip install --break-system*)"
    ]
  }
}
